# OS / editor cruft
.DS_Store

# === Secrets — never commit (this repo is PUBLIC) ===

# Claude Code (when added as the `claude` package)
claude/**/.credentials.json
claude/**/settings.local.json
claude/**/projects/
claude/**/history.jsonl
claude/**/todos/
claude/**/statsig/
claude/**/shell-snapshots/

# Codex (when added as the `codex` package)
codex/**/auth.json
codex/**/sessions/
codex/**/history
codex/**/log/

# Shell machine-local secrets (sourced by .zshrc, never tracked)
.zshrc.local
zsh/.zshrc.local
.bashrc.local

# Generic secret material
*.pem
*.key
id_rsa
id_ed25519
.env
.env.*
